{
  "name": "@fluxwind/core",
  "version": "0.3.4",
  "description": "FluxWind UI — Extensible design system with atomic components, WCAG 2.2 AA, theming, and transitions.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauriciodelrio/fluxwind-ui"
  },
  "homepage": "https://github.com/mauriciodelrio/fluxwind-ui#readme",
  "bugs": {
    "url": "https://github.com/mauriciodelrio/fluxwind-ui/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "style": "./dist/styles/index.css",
      "default": "./dist/styles/index.css"
    },
    "./styles/themes/health": {
      "style": "./dist/styles/themes/health.css",
      "default": "./dist/styles/themes/health.css"
    },
    "./styles/themes/legal": {
      "style": "./dist/styles/themes/legal.css",
      "default": "./dist/styles/themes/legal.css"
    },
    "./styles/themes/commerce": {
      "style": "./dist/styles/themes/commerce.css",
      "default": "./dist/styles/themes/commerce.css"
    },
    "./styles/themes/finance": {
      "style": "./dist/styles/themes/finance.css",
      "default": "./dist/styles/themes/finance.css"
    },
    "./styles/themes/creative": {
      "style": "./dist/styles/themes/creative.css",
      "default": "./dist/styles/themes/creative.css"
    },
    "./styles/themes/education": {
      "style": "./dist/styles/themes/education.css",
      "default": "./dist/styles/themes/education.css"
    },
    "./styles/themes/high-contrast": {
      "style": "./dist/styles/themes/high-contrast.css",
      "default": "./dist/styles/themes/high-contrast.css"
    },
    "./themes/health": {
      "style": "./dist/styles/themes/health.css",
      "default": "./dist/styles/themes/health.css"
    },
    "./themes/legal": {
      "style": "./dist/styles/themes/legal.css",
      "default": "./dist/styles/themes/legal.css"
    },
    "./themes/commerce": {
      "style": "./dist/styles/themes/commerce.css",
      "default": "./dist/styles/themes/commerce.css"
    },
    "./themes/finance": {
      "style": "./dist/styles/themes/finance.css",
      "default": "./dist/styles/themes/finance.css"
    },
    "./themes/creative": {
      "style": "./dist/styles/themes/creative.css",
      "default": "./dist/styles/themes/creative.css"
    },
    "./themes/education": {
      "style": "./dist/styles/themes/education.css",
      "default": "./dist/styles/themes/education.css"
    },
    "./themes/high-contrast": {
      "style": "./dist/styles/themes/high-contrast.css",
      "default": "./dist/styles/themes/high-contrast.css"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build && pnpm run copy:styles",
    "copy:styles": "mkdir -p dist/styles/themes && cp src/styles/index.css dist/styles/index.css && cp src/styles/themes/*.css dist/styles/themes/",
    "dev": "vite build --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist",
    "release": "release-it"
  },
  "peerDependencies": {
    "@radix-ui/react-slot": ">=1.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@radix-ui/react-slot": {
      "optional": false
    }
  },
  "dependencies": {
    "@preact/signals-react": "3.10.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@preact/signals-react-transform": "0.8.1",
    "@release-it/conventional-changelog": "10.0.6",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "axe-core": "4.11.3",
    "jsdom": "29.0.2",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "release-it": "19.2.4",
    "simple-icons": "16.16.0",
    "storybook": "10.3.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.4"
  }
}
